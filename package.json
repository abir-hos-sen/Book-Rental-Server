    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "stripe": "^15.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
